# LeanReserve Environment Variables
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email Service (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
FROM_EMAIL=bookings@yourdomain.com

# ElevenLabs AI Integration (Optional)
# Get your API key from: https://elevenlabs.io/subscription
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Application Settings
# The default restaurant ID for the booking form (for MVP/single-restaurant setup)
DEFAULT_RESTAURANT_ID=00000000-0000-0000-0000-000000000000